{
  "mcpServers": {
    "workiq": {
      "command": "npx",
      "args": [
        "-y",
        "@microsoft/workiq@latest",
        "mcp"
      ],
      "tools": [
        "*"
      ]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "ado": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@azure-devops/mcp",
        "${input:ado_org}"
      ]
    }
  }
}